{
  "name": "signing-gateway",
  "version": "0.2.0",
  "description": "Signing gateway: HIS4 -> VNPT-CA Plugin -> USB Token",
  "main": "server.js",
  "bin": "server.js",
  "scripts": {
    "start": "node server.js",
    "build": "pkg . --targets node22-win-x64 --output dist/signing-gateway.exe"
  },
  "dependencies": {
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.3.0"
  },
  "pkg": {
    "targets": [
      "node22-win-x64"
    ],
    "outputPath": "dist",
    "assets": [
      "bin/pdf-signer.exe",
      "font.ttf"
    ]
  }
}
